
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── STEP 2: Add when setting up Meta Webhook ─────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=

# ── STEP 3: Add when setting up PostgreSQL ───────────────────
DB_USER=salon_user
DB_PASSWORD=change_me
DB_HOST=postgres
DB_PORT=5432
DB_NAME=salon_agent
DATABASE_URL=postgresql+asyncpg://salon_user:change_me@postgres:5432/salon_agent

# ── STEP 4: Add when setting up Redis ────────────────────────
REDIS_URL=redis://redis:6379/0

# ── STEP 5: Add when connecting CRM ─────────────────────────
DEFAULT_CRM_BASE_URL=
DEFAULT_CRM_API_KEY=

# ── STEP 6: Add for human handoff alerts ─────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL=

# ── STEP 7: Add for error tracking ───────────────────────────
SENTRY_DSN=

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
